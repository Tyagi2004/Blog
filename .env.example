# MongoDB connection string.
# Local MongoDB example:
MONGO_URI=mongodb://127.0.0.1:27017/devsphere

# MongoDB Atlas (cloud) example:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/devsphere

# Secret used to sign session cookies. Use a long random string in production.
SESSION_SECRET=change-this-to-a-long-random-string

# Port the server runs on (optional, defaults to 8080)
PORT=8080
